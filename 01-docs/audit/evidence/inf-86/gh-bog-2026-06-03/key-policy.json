{
  "Policy": "{\n  \"Version\" : \"2012-10-17\",\n  \"Statement\" : [ {\n    \"Sid\" : \"EnableRootAccountAdmin\",\n    \"Effect\" : \"Allow\",\n    \"Principal\" : {\n      \"AWS\" : \"arn:aws:iam::348389439381:root\"\n    },\n    \"Action\" : \"kms:*\",\n    \"Resource\" : \"*\"\n  }, {\n    \"Sid\" : \"AllowSovereignSign\",\n    \"Effect\" : \"Allow\",\n    \"Principal\" : {\n      \"AWS\" : \"arn:aws:iam::348389439381:role/gtcx-production-platforms-irsa\"\n    },\n    \"Action\" : [ \"kms:Sign\", \"kms:GetPublicKey\", \"kms:DescribeKey\" ],\n    \"Resource\" : \"*\",\n    \"Condition\" : {\n      \"StringEquals\" : {\n        \"kms:SigningAlgorithm\" : \"ECDSA_SHA_256\"\n      }\n    }\n  }, {\n    \"Sid\" : \"AllowKeyAdministration\",\n    \"Effect\" : \"Allow\",\n    \"Principal\" : {\n      \"AWS\" : \"arn:aws:iam::348389439381:role/gtcx-production-shared-deploy\"\n    },\n    \"Action\" : [ \"kms:Update*\", \"kms:UntagResource\", \"kms:TagResource\", \"kms:ScheduleKeyDeletion\", \"kms:Revoke*\", \"kms:Put*\", \"kms:List*\", \"kms:Get*\", \"kms:Enable*\", \"kms:Disable*\", \"kms:Describe*\", \"kms:Delete*\", \"kms:Create*\", \"kms:CancelKeyDeletion\" ],\n    \"Resource\" : \"*\"\n  }, {\n    \"Sid\" : \"DenyKeyExport\",\n    \"Effect\" : \"Deny\",\n    \"Principal\" : {\n      \"AWS\" : \"*\"\n    },\n    \"Action\" : [ \"kms:ImportKeyMaterial\", \"kms:GetKeyRotationStatus\" ],\n    \"Resource\" : \"*\",\n    \"Condition\" : {\n      \"StringNotEquals\" : {\n        \"aws:PrincipalArn\" : \"arn:aws:iam::348389439381:root\"\n      }\n    }\n  } ]\n}",
  "PolicyName": "default"
}
