{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gtcx.org/schemas/audit/root-allowlist.schema.json",
  "title": "Repo Root Allowlist",
  "description": "Canonical schema for 01-docs/04-ops/repo/root-allowlist.json. Consumed by 03-platform/scripts/ops/check-workspace-root-cleanliness.py. Owned by gtcx-docs/03-platform/tools/audit/audit-framework/schemas/root-allowlist.schema.json.",
  "type": "object",
  "required": ["version", "required_files", "allowed_files", "allowed_directories"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema reference (relative or absolute URL)."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semver of the allowlist content (per repo). Bump when entries change."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this schema the allowlist conforms to. Optional; checker uses for upgrade hints."
    },
    "updated": {
      "type": "string",
      "format": "date",
      "description": "ISO date of last edit."
    },
    "description": {
      "type": "string"
    },
    "required_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "allowed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "allowed_directories": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "pattern": "^[^./].*$" },
      "uniqueItems": true
    },
    "allowed_dot_directories": {
      "type": "array",
      "items": { "type": "string", "minLength": 2, "pattern": "^\\..*$" },
      "uniqueItems": true
    },
    "ignored_prefixes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "ignored_exact": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "deprecated_files": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "forbidden_root_names": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "forbidden_name_prefixes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "human_owned_paths": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["owner", "agent_action", "ci_enforcement"],
        "additionalProperties": false,
        "properties": {
          "owner": { "type": "string" },
          "agent_action": { "type": "string" },
          "ci_enforcement": { "type": "string" },
          "audit_reporting": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "relocate_hints": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}
