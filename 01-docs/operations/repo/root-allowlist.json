{
  "$schema": "./root-allowlist.schema.json",
  "version": "3.2.0",
  "schema_version": "1.0.0",
  "migration_tier": "stable",
  "updated": "2026-06-06",
  "description": "Universal seven-hub root allowlist (ecosystem layout v3). Closed world — Protocol 31. No per-repo exceptions.",
  "required_files": ["README.md", "AGENTS.md"],
  "required_directories": [
    "00-archive",
    "01-docs",
    "02-ops",
    "03-platform",
    "04-deploy",
    "05-audit",
    "06-workstream",
    "config"
  ],
  "allowed_files": [
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "package.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "turbo.json",
    "tsconfig.json",
    "eslint.config.js",
    "commitlint.config.js",
    "baseline.config.ts",
    "baseline.config.json",
    "hygiene.config.json",
    "pyproject.toml",
    "Cargo.toml",
    "Makefile",
    "Makefile.local",
    ".dockerignore",
    ".editorconfig",
    ".env.example",
    ".eslintignore",
    ".eslintrc.js",
    ".gitignore",
    ".gitattributes",
    ".npmrc",
    ".nvmrc",
    ".prettierignore",
    ".prettierrc",
    ".size-limit.json"
  ],
  "allowed_directories": [
    "00-archive",
    "01-docs",
    "02-ops",
    "03-platform",
    "04-deploy",
    "05-audit",
    "06-workstream",
    "config",
    "rust"
  ],
  "allowed_dot_directories": [
    ".github",
    ".husky",
    ".agent",
    ".baseline",
    ".cursor",
    ".claude",
    ".gemini",
    ".kimi",
    ".gtcx",
    ".turbo",
    ".changeset",
    ".vitepress"
  ],
  "ignored_prefixes": [".", "node_modules"],
  "ignored_exact": ["node_modules"],
  "forbidden_root_names": {
    "audit": "Use 05-audit/.",
    "assets": "Use 03-platform/assets/.",
    "workstream": "Use 06-workstream/.",
    "coverage": "Build artifact — gitignored.",
    "session-notes": "Use 01-docs/session-notes/.",
    "_archive": "Gitignored at root.",
    "04-ship": "Renamed to 04-deploy/ (layout v3).",
    "Dockerfile": "Use 04-deploy/docker/Dockerfile.",
    "docker-compose.yml": "Use 04-deploy/docker/docker-compose.yml.",
    "render.yaml": "Use 04-deploy/render.yaml.",
    "typedoc.json": "Use config/toolchain/typedoc.json.",
    "vitest.workspace.ts": "Use config/toolchain/vitest.workspace.ts.",
    "CLAUDE.md": "Use .claude/CLAUDE.md.",
    "GEMINI.md": "Use .gemini/GEMINI.md.",
    "CONVENTIONS.md": "Use 01-docs/conventions.md.",
    "CODE_OF_CONDUCT.md": "Use 01-docs/operations/repo/CODE_OF_CONDUCT.md (Protocol 31).",
    "CONTRIBUTING.md": "Use 01-docs/operations/repo/CONTRIBUTING.md (Protocol 31).",
    "SECURITY.md": "Use 01-docs/operations/repo/SECURITY.md (Protocol 32).",
    "public": "Use 04-deploy/static/ or 03-platform/public/.",
    "screenshots": "Use 03-platform/assets/screenshots/.",
    "ExpoNative": "Use 03-platform/reference/exponative/.",
    "apps": "Use 03-platform/apps/.",
    "services": "Use 03-platform/services/.",
    "packages": "Use 03-platform/packages/.",
    "infra": "Use 04-deploy/ or 03-platform/."
  },
  "forbidden_name_prefixes": ["IMG_", "Screenshot", "Untitled"],
  "human_owned_paths": {
    "_delete": {
      "owner": "repository maintainer (manual)",
      "agent_action": "none",
      "ci_enforcement": "excluded from root-cleanliness check",
      "audit_reporting": "may note as out-of-scope",
      "rationale": "Maintainer-managed terminal cleanup."
    }
  },
  "relocate_hints": {
    "audits": "01-docs/05-audit/",
    "repo_policy": "01-docs/operations/repo/",
    "deploy_docker": "04-deploy/docker/",
    "toolchain": "config/toolchain/",
    "shared_assets": "03-platform/assets/",
    "workstream": "06-workstream/",
    "community_docs": "01-docs/operations/repo/",
    "static_deploy": "04-deploy/static/",
    "ui_reference": "03-platform/reference/exponative/"
  }
}
