{
  "$schema": "./root-allowlist.schema.json",
  "version": "2.0.0",
  "schema_version": "1.0.0",
  "updated": "2026-06-05",
  "description": "Root allowlist for gtcx-infrastructure (five-hub v2).",
  "required_files": ["README.md", "AGENTS.md"],
  "allowed_files": [
    ".dockerignore",
    ".editorconfig",
    ".env.example",
    ".eslintignore",
    ".eslintrc.js",
    ".gitattributes",
    ".gitignore",
    ".npmrc",
    ".nvmrc",
    ".prettierignore",
    ".prettierrc",
    ".size-limit.json",
    "AGENTS.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "Cargo.toml",
    "LICENSE",
    "Makefile",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "baseline.config.json",
    "baseline.config.ts",
    "commitlint.config.js",
    "eslint.config.js",
    "eslint.config.mjs",
    "hygiene.config.json",
    "mise.toml",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "pyproject.toml",
    "renovate.json",
    "tsconfig.json",
    "turbo.json"
  ],
  "allowed_directories": [
    ".agent",
    ".baseline",
    ".claude",
    ".cursor",
    ".gemini",
    ".github",
    ".husky",
    ".kimi",
    ".turbo",
    "00-archive",
    "01-docs",
    "02-ops",
    "03-platform",
    "04-ship",
    "05-audit",
    "config",
    "rust"
  ],
  "allowed_dot_directories": [
    ".github",
    ".husky",
    ".agent",
    ".baseline",
    ".cursor",
    ".claude",
    ".gemini",
    ".kimi",
    ".gtcx",
    ".turbo",
    ".changeset",
    ".vitepress"
  ],
  "ignored_prefixes": [".", "node_modules"],
  "ignored_exact": ["node_modules"],
  "forbidden_root_names": {
    "audit": "Move to 01-docs/05-audit/.",
    "coverage": "Build artifact — gitignored.",
    "session-notes": "Use 01-docs/session-notes/.",
    "_archive": "Gitignored at root.",
    "Dockerfile": "Use 04-ship/docker/Dockerfile.",
    "docker-compose.yml": "Use 04-ship/docker/docker-compose.yml.",
    "dist": "Build artifact — gitignored.",
    "infra": "Use 04-ship/ (docker, kubernetes, terraform, migrations).",
    "typedoc.json": "Use config/toolchain/typedoc.json.",
    "vitest.workspace.ts": "Use config/toolchain/vitest.workspace.ts.",
    "CLAUDE.md": "Use .claude/CLAUDE.md.",
    "GEMINI.md": "Use .gemini/GEMINI.md.",
    "CONVENTIONS.md": "Use 01-docs/conventions.md."
  },
  "forbidden_name_prefixes": ["IMG_", "Screenshot", "Untitled"],
  "human_owned_paths": {
    "_delete": {
      "owner": "repository maintainer (manual)",
      "agent_action": "none",
      "ci_enforcement": "excluded from root-cleanliness check",
      "audit_reporting": "may note as out-of-scope",
      "rationale": "Maintainer-managed terminal cleanup."
    }
  },
  "relocate_hints": {
    "audits": "01-docs/05-audit/",
    "repo_policy": "01-docs/operations/repo/",
    "ship_docker": "04-ship/docker/",
    "toolchain": "config/toolchain/"
  }
}
