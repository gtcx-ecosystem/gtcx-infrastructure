{
  "name": "@gtcx/ussd-handler",
  "version": "0.1.0",
  "description": "GTCX USSD Handler — feature-phone gateway for trade compliance across African markets",
  "type": "module",
  "main": "src/server.mjs",
  "scripts": {
    "lint": "eslint src tests --ext .mjs,.js",
    "start": "node src/server.mjs",
    "dev": "node --watch src/server.mjs",
    "test": "node ../scripts/run-package-tests.mjs",
    "test:coverage": "c8 --reporter=text --reporter=json --reporter=lcov --include='src/**' node ../scripts/run-package-tests.mjs",
    "test:coverage:gate": "c8 --check-coverage --branches 90 --statements 90 --functions 90 --lines 90 --reporter=text --reporter=json --reporter=lcov --include='src/**' node ../scripts/run-package-tests.mjs",
    "typecheck": "echo \"No TypeScript files — typecheck is a no-op for this JS-only package\"",
    "build": "echo \"No build step required — this package runs directly with Node.js ESM\""
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "keywords": [
    "gtcx",
    "ussd",
    "global-south",
    "african-fintech",
    "feature-phone",
    "mobile-money"
  ],
  "license": "MIT",
  "private": true,
  "optionalDependencies": {
    "ioredis": "^5.10.1"
  }
}
