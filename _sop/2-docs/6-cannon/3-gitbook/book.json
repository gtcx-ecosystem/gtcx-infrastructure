{
  "title": "[Organization Name]",
  "description": "[Platform tagline — e.g., Intelligence Infrastructure for [Market]]",
  "author": "[Organization Name]",
  "language": "en",
  "gitbook": ">=3.2.0",
  "root": ".",
  "structure": {
    "readme": "README.md",
    "summary": "summary.md"
  },
  "plugins": ["search", "highlight", "sharing", "fontsettings", "theme-default"],
  "pluginsConfig": {
    "theme-default": {
      "showLevel": false
    },
    "sharing": {
      "facebook": false,
      "twitter": true,
      "linkedin": true
    }
  },
  "links": {
    "sidebar": {
      "[Organization Name]": "[organization-url]",
      "API Status": "[status-url]"
    }
  }
}
