# =============================================================================
# GTCX Infrastructure — Environment Variables
# =============================================================================
# Copy to .env and customize. All variables have dev defaults in docker-compose.
# =============================================================================

# PostgreSQL (Operational)
POSTGRES_USER=gtcx
POSTGRES_PASSWORD=gtcx_dev_password
POSTGRES_DB=gtcx_development

# PostgreSQL (Audit — separate instance)
POSTGRES_AUDIT_USER=gtcx_audit
POSTGRES_AUDIT_PASSWORD=gtcx_audit_dev_password
POSTGRES_AUDIT_DB=gtcx_audit

# Rails
SECRET_KEY_BASE=dev_secret_key_base_change_in_production

# Grafana
GF_ADMIN_PASSWORD=admin

# Alertmanager (local infra compose only)
# Set to 1 to allow CHANGE_ME_DEV / no-op Slack URLs in alertmanager-config-init.
GTCX_ALERTS_DEV_MODE=1
# PAGERDUTY_SERVICE_KEY=
# PAGERDUTY_INTELLIGENCE_ROUTING_KEY=
# SLACK_WEBHOOK_URL=
# SLACK_INCIDENT_WEBHOOK=

# NATS authentication (per-service credentials)
NATS_PLATFORM_PASS=platform-dev-secret
NATS_PROTOCOLS_PASS=protocols-dev-secret
NATS_INTELLIGENCE_PASS=intelligence-dev-secret

# Intelligence services
ANTHROPIC_API_KEY=
SCREENING_PROVIDER=local
COMPLY_ADVANTAGE_API_KEY=
