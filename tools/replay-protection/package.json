{
  "name": "@gtcx/replay-protection",
  "version": "0.1.0",
  "description": "GTCX Replay Protection — nonce store, timestamp window enforcement, clock-skew tolerance, and audit capture for offline field operations",
  "type": "module",
  "main": "src/verifier.mjs",
  "exports": {
    ".": "./src/verifier.mjs",
    "./server": "./src/server.mjs",
    "./middleware": "./src/middleware.mjs",
    "./store": "./src/store/nonce-store.mjs",
    "./store/memory": "./src/store/memory-nonce-store.mjs",
    "./store/redis": "./src/store/redis-nonce-store.mjs",
    "./policy/clock-skew": "./src/policy/clock-skew.mjs",
    "./audit": "./src/audit/audit-capture.mjs",
    "./metrics": "./src/metrics/replay-metrics.mjs",
    "./logging": "./src/logging/auth-failure-logger.mjs",
    "./crypto/did-verify": "./src/crypto/did-verify.mjs",
    "./crypto/hash": "./src/crypto/hash.mjs"
  },
  "scripts": {
    "test": "node ../scripts/run-package-tests.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "test:coverage": "c8 --reporter=text --reporter=json --reporter=lcov --include='src/**' --exclude='tests/**' node ../scripts/run-package-tests.mjs",
    "test:coverage:gate": "c8 --reporter=text --check-coverage --branches=90 --statements=90 --functions=90 --lines=90 --include='src/**' --exclude='tests/**' node ../scripts/run-package-tests.mjs",
    "lint": "eslint --ext .mjs,.js src tests",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "dependencies": {
    "@gtcx/crypto": "^3.1.4",
    "pg": "^8.15.0"
  },
  "peerDependencies": {
    "redis": "^4.6.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "gtcx",
    "replay-protection",
    "nonce",
    "security",
    "offline-queue",
    "audit"
  ],
  "license": "MIT",
  "private": true
}
