{
  "name": "@gtcx/eval-pipeline",
  "version": "0.1.0",
  "description": "GTCX AI output evaluation pipeline — benchmark runner and CI gate",
  "type": "module",
  "private": true,
  "scripts": {
    "eval": "node eval.mjs",
    "eval:all": "node eval.mjs --all",
    "eval:injection": "node injection-suite.mjs",
    "test": "node ../scripts/run-package-tests.mjs",
    "test:coverage:gate": "node ../scripts/run-package-tests.mjs"
  },
  "dependencies": {
    "@gtcx/compliance-gateway": "workspace:*"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "keywords": [
    "gtcx",
    "eval",
    "ai",
    "benchmark"
  ]
}
