{
  "$schema": "https://gtcx.org/schemas/audit/root-allowlist.schema.json",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "updated": "2026-06-05",
  "description": "Repo-specific root allowlist for gtcx-infrastructure. Source of truth for CI root-cleanliness checks. Mirrors docs/operations/repo/repo-hygiene-protocol.md.",

  "required_files": ["README.md", "AGENTS.md"],

  "allowed_files": [
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CLAUDE.md",
    "CODEX.md",
    "GEMINI.md",
    "KIMI.md",
    "CONVENTIONS.md",
    "package.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "turbo.json",
    "tsconfig.json",
    "eslint.config.mjs",
    "mise.toml",
    "renovate.json",
    ".docs-exceptions.json",
    ".gitignore",
    ".gitattributes",
    ".editorconfig",
    ".eslintignore",
    ".npmrc",
    ".nvmrc",
    ".prettierignore",
    ".prettierrc",
    ".env.example"
  ],

  "allowed_directories": ["docs", "infra", "scripts", "tools", "workspace", "agents"],

  "allowed_dot_directories": [
    ".github",
    ".husky",
    ".agent",
    ".baseline",
    ".cursor",
    ".kimi",
    ".zap",
    ".claude"
  ],

  "ignored_prefixes": [".", "node_modules"],

  "ignored_exact": ["node_modules"],

  "deprecated_files": {},

  "forbidden_root_names": {
    "audit": "Move to docs/audit/ or docs/audit/_historical/.",
    "session-notes": "Use docs/session-notes/.",
    "_archive": "Gitignored historical tree; must not be committed at root."
  },

  "forbidden_name_prefixes": ["IMG_", "Screenshot", "Untitled"],

  "human_owned_paths": {
    "_delete": {
      "owner": "repository maintainer (manual)",
      "agent_action": "none — do not delete, move, empty, or schedule in sprints/PRs",
      "ci_enforcement": "excluded from root-cleanliness check",
      "audit_reporting": "may note as out-of-scope; never score as P0/P1",
      "rationale": "Maintainer-managed terminal cleanup."
    },
    "_archive": {
      "owner": "repository maintainer (manual)",
      "agent_action": "none — gitignored local reference only",
      "ci_enforcement": "excluded from root-cleanliness check",
      "audit_reporting": "out-of-scope",
      "rationale": "Local archive reference; never tracked at root."
    },
    "_cannon": {
      "owner": "repository maintainer (manual)",
      "agent_action": "none — gitignored local reference only",
      "ci_enforcement": "excluded from root-cleanliness check",
      "audit_reporting": "out-of-scope",
      "rationale": "Local reference tree; never tracked at root."
    }
  },

  "relocate_hints": {
    "audits": "docs/audit/",
    "session_analysis": "docs/session-notes/",
    "local_scratch": ".local/",
    "pm_artifacts": "docs/agile/",
    "repo_policy": "docs/operations/repo/",
    "deploy_evidence": "docs/audit/evidence/",
    "agent_terminal_index": "agents/",
    "operational_workspace": "workspace/",
    "production_scripts": "scripts/production/"
  }
}
