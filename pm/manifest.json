{
  "$schema": "gtcx://pm/manifest/v5",
  "schema": "gtcx.pm.manifest.v5",
  "repo": "gtcx-infrastructure",
  "layoutVersion": "v5",
  "updated": "2026-06-09",
  "agileHub": null,
  "ux": "pm/ux",
  "product": "pm/product",
  "local": {
    "executionRoadmap": "audit/product-management/execution-roadmap.md",
    "workSelection": "docs/operations/agent-work-selection.md",
    "autoDevState": "audit/product-management/auto-dev-state.md",
    "nextWorkScript": "platform/scripts/agent-next-work.mjs",
    "completionModel": "pm/completion-model.json",
    "initiatives": "pm/roadmap/initiatives.json"
  },
  "sync": {
    "command": "pnpm pm:sync",
    "output": "ops/pm/backlog.json"
  },
  "generate": {
    "daas": {
      "command": "pnpm generate:roadmap",
      "sources": ["pm/daas-roadmap.json", "pm/friction-register.json", "pm/daas-stories.json"],
      "output": "audit/product-management/execution-roadmap.md"
    },
    "secas": {
      "command": "pnpm generate:secas-roadmap",
      "sources": [
        "pm/secas-roadmap.json",
        "pm/security-friction-register.json",
        "pm/secas-stories.json",
        "pm/sovereign-approval-register.json"
      ],
      "output": "audit/product-management/secas-execution-roadmap.md"
    }
  }
}
