{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "SIGNAL L5 — Confidence Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Confidence Distribution (Heatmap)",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(intelligence_confidence_bucket[5m])) by (le)",
          "legendFormat": "{{ le }}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "color": { "mode": "scheme", "scheme": "Spectral", "steps": 128 },
        "yAxis": { "unit": "none", "min": 0, "max": 1 }
      }
    },
    {
      "title": "Median Confidence (P50)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(intelligence_confidence_bucket[15m])) by (le))",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "title": "P95 Confidence",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(intelligence_confidence_bucket[15m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "title": "Drift Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "intelligence_confidence_drift{service=\"sdk-server\"}",
          "legendFormat": "Drift Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Stable", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DRIFTING", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Escalation Rate",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 6 },
      "targets": [
        {
          "expr": "rate(intelligence_escalation_total[1h]) / rate(intelligence_requests_total[1h])",
          "legendFormat": "Escalation %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      }
    },
    {
      "title": "Auto-Approve Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "targets": [
        {
          "expr": "rate(intelligence_auto_approved_total[1h])",
          "legendFormat": "Auto-approved / hour"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "Confidence Trend (P25 / P50 / P75)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "targets": [
        {
          "expr": "histogram_quantile(0.25, sum(rate(intelligence_confidence_bucket[30m])) by (le))",
          "legendFormat": "P25"
        },
        {
          "expr": "histogram_quantile(0.5, sum(rate(intelligence_confidence_bucket[30m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.75, sum(rate(intelligence_confidence_bucket[30m])) by (le))",
          "legendFormat": "P75"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "title": "SIGNAL L5 — Fine-Tune Cycle",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false
    },
    {
      "title": "Shadow: Stable vs Candidate Confidence Delta",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "intelligence_shadow_confidence_delta",
          "legendFormat": "{{ service }} delta"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "title": "Shadow: Agreement Rate",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "intelligence_shadow_agreement_rate",
          "legendFormat": "Agreement"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "title": "Model Version in Production",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "targets": [
        {
          "expr": "intelligence_model_version_info",
          "legendFormat": "{{ model_id }}:{{ version }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "string" }
      }
    },
    {
      "title": "Training Dataset Size",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "intelligence_dataset_size_total",
          "legendFormat": "Samples"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 10000 }
            ]
          }
        }
      }
    },
    {
      "title": "SIGNAL L5 — Feedback Loop",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false
    },
    {
      "title": "Corrections Per Hour",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "targets": [
        {
          "expr": "sum(rate(intelligence_feedback_total[1h])) by (service)",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "title": "Corrections by Service",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 29 },
      "targets": [
        {
          "expr": "sum(increase(intelligence_feedback_total[24h])) by (service)",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "title": "Time Since Last Feedback",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 29 },
      "targets": [
        {
          "expr": "time() - intelligence_last_feedback_timestamp",
          "legendFormat": "Since last"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 86400 },
              { "color": "red", "value": 604800 }
            ]
          }
        }
      }
    },
    {
      "title": "Dataset Growth Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 33 },
      "targets": [
        {
          "expr": "intelligence_dataset_size_total",
          "legendFormat": "Total samples"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["intelligence", "signal-l5", "ml-pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Intelligence — SIGNAL L5 Self-Improvement",
  "uid": "intelligence-l5"
}
