{
  "dashboard": {
    "id": null,
    "uid": "gtcx-security-kpis",
    "title": "GTCX Security KPIs",
    "tags": ["gtcx", "security", "kpi", "executive"],
    "timezone": "UTC",
    "schemaVersion": 36,
    "refresh": "5m",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "MTTR by Severity (days)",
        "description": "Mean time to resolve security incidents, broken down by severity level",
        "type": "bargauge",
        "targets": [
          {
            "expr": "security:mttr:days{severity=\"critical\"}",
            "legendFormat": "Critical"
          },
          {
            "expr": "security:mttr:days{severity=\"high\"}",
            "legendFormat": "High"
          },
          {
            "expr": "security:mttr:days{severity=\"medium\"}",
            "legendFormat": "Medium"
          },
          {
            "expr": "security:mttr:days{severity=\"low\"}",
            "legendFormat": "Low"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "d",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 7 },
                { "color": "orange", "value": 14 },
                { "color": "red", "value": 30 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Vulnerability Density (open vulns / 1K LOC)",
        "description": "Open vulnerabilities normalized per 1,000 lines of code",
        "type": "stat",
        "targets": [
          {
            "expr": "security:vulnerability_density:per_1k_loc",
            "legendFormat": "Vuln Density"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.5 },
                { "color": "orange", "value": 1.0 },
                { "color": "red", "value": 2.0 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
      },
      {
        "id": 3,
        "title": "Patch Latency (days from CVE to patch)",
        "description": "Average days from CVE public disclosure to patch applied in production",
        "type": "stat",
        "targets": [
          {
            "expr": "security:patch_latency:days_avg",
            "legendFormat": "Avg Patch Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "d",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 7 },
                { "color": "orange", "value": 14 },
                { "color": "red", "value": 30 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
      },
      {
        "id": 4,
        "title": "Pen-Test Findings Trend",
        "description": "Open penetration test findings over time by severity",
        "type": "graph",
        "targets": [
          {
            "expr": "security:pentest_findings:open{severity=\"critical\"}",
            "legendFormat": "Critical"
          },
          {
            "expr": "security:pentest_findings:open{severity=\"high\"}",
            "legendFormat": "High"
          },
          {
            "expr": "security:pentest_findings:open{severity=\"medium\"}",
            "legendFormat": "Medium"
          },
          {
            "expr": "security:pentest_findings:open{severity=\"low\"}",
            "legendFormat": "Low"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Critical" },
              "properties": [{ "id": "color", "value": { "fixedColor": "red" } }]
            },
            {
              "matcher": { "id": "byName", "options": "High" },
              "properties": [{ "id": "color", "value": { "fixedColor": "orange" } }]
            },
            {
              "matcher": { "id": "byName", "options": "Medium" },
              "properties": [{ "id": "color", "value": { "fixedColor": "yellow" } }]
            },
            {
              "matcher": { "id": "byName", "options": "Low" },
              "properties": [{ "id": "color", "value": { "fixedColor": "blue" } }]
            }
          ]
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
      },
      {
        "id": 5,
        "title": "Code Coverage %",
        "description": "Overall test code coverage across the GTCX ecosystem",
        "type": "gauge",
        "targets": [
          {
            "expr": "security:code_coverage:ratio",
            "legendFormat": "Coverage"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 0.6 },
                { "color": "yellow", "value": 0.75 },
                { "color": "green", "value": 0.85 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 }
      },
      {
        "id": 6,
        "title": "Audit Coverage %",
        "description": "Percentage of expected audit events that are captured and stored",
        "type": "gauge",
        "targets": [
          {
            "expr": "security:audit_coverage:ratio",
            "legendFormat": "Audit Coverage"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 0.8 },
                { "color": "yellow", "value": 0.9 },
                { "color": "green", "value": 0.95 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 }
      },
      {
        "id": 7,
        "title": "Compliance Drift (OPA/Kyverno Violations)",
        "description": "Number of active policy violations detected by admission controllers",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(kyverno_policy_results_total{rule_result=\"fail\"})",
            "legendFormat": "Active Violations"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "orange", "value": 5 },
                { "color": "red", "value": 10 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 }
      },
      {
        "id": 8,
        "title": "MFA Enrollment Rate",
        "description": "Percentage of active users with MFA enabled",
        "type": "gauge",
        "targets": [
          {
            "expr": "security:mfa_enrollment:ratio",
            "legendFormat": "MFA Enrollment"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 0.8 },
                { "color": "yellow", "value": 0.9 },
                { "color": "green", "value": 0.95 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 }
      },
      {
        "id": 9,
        "title": "Key Rotation Compliance",
        "description": "Percentage of cryptographic keys rotated within policy window",
        "type": "gauge",
        "targets": [
          {
            "expr": "security:key_rotation:compliance_ratio",
            "legendFormat": "Key Rotation"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 0.8 },
                { "color": "yellow", "value": 0.9 },
                { "color": "green", "value": 1.0 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 }
      },
      {
        "id": 10,
        "title": "Open Vulnerabilities by Severity",
        "description": "Current count of open vulnerabilities across all services",
        "type": "bargauge",
        "targets": [
          {
            "expr": "security:open_vulnerabilities:count{severity=\"critical\"}",
            "legendFormat": "Critical"
          },
          {
            "expr": "security:open_vulnerabilities:count{severity=\"high\"}",
            "legendFormat": "High"
          },
          {
            "expr": "security:open_vulnerabilities:count{severity=\"medium\"}",
            "legendFormat": "Medium"
          },
          {
            "expr": "security:open_vulnerabilities:count{severity=\"low\"}",
            "legendFormat": "Low"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 5 },
                { "color": "orange", "value": 15 },
                { "color": "red", "value": 30 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 }
      },
      {
        "id": 11,
        "title": "Compliance Violations Trend (30d)",
        "description": "Kyverno policy violations over time, showing compliance drift direction",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(increase(kyverno_policy_results_total{rule_result=\"fail\"}[1d]))",
            "legendFormat": "Daily Violations"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15
            }
          }
        },
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 }
      }
    ]
  }
}
