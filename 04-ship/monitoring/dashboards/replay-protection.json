{
  "annotations": {
    "list": []
  },
  "description": "GTCX Replay Protection — nonce, timestamp, envelope, and signature verification telemetry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Replay Decisions (rate/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(replay_protection_total[5m])) by (code)",
          "legendFormat": "{{ code }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Rejection Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(replay_protection_total) by (code)",
          "legendFormat": "{{ code }}"
        }
      ]
    },
    {
      "title": "Nonce Rejections — Replay Attack Indicator",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(replay_protection_total{code=\"REPLAY_NONCE\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "title": "Stale / Future Rejections — Clock Drift",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(replay_protection_total{code=\"REPLAY_STALE\"}[5m])) by (pod)",
          "legendFormat": "stale — {{ pod }}"
        },
        {
          "expr": "sum(rate(replay_protection_total{code=\"REPLAY_FUTURE\"}[5m])) by (pod)",
          "legendFormat": "future — {{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Envelope & Signature Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(replay_protection_total{code=\"REPLAY_ENVELOPE\"}[5m])) by (pod)",
          "legendFormat": "envelope — {{ pod }}"
        },
        {
          "expr": "sum(rate(replay_protection_total{code=\"REPLAY_SIGNATURE\"}[5m])) by (pod)",
          "legendFormat": "signature — {{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Redis Store Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "replay_guard_redis_connected",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FALLBACK (MEMORY)" },
                "1": { "text": "CONNECTED" }
              }
            }
          ]
        }
      }
    },
    {
      "title": "Acceptance Rate %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "(sum(rate(replay_protection_total{code=\"REPLAY_OK\"}[5m])) / sum(rate(replay_protection_total[5m]))) * 100",
          "legendFormat": "acceptance %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Clock Skew Distribution (ms)",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(replay_protection_clock_skew_ms_bucket[5m])) by (le)",
          "legendFormat": "{{ le }}"
        }
      ],
      "dataFormat": "tsbuckets"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["security", "replay-protection", "mobile"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values(replay_protection_total, namespace)",
        "current": { "text": "gtcx", "value": "gtcx" }
      },
      {
        "name": "pod",
        "type": "query",
        "query": "label_values(replay_protection_total{namespace=~\"$namespace\"}, pod)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GTCX Replay Protection",
  "uid": "gtcx-replay-protection",
  "version": 1
}
