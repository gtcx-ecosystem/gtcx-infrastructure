{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-tenant view of the audit trust telemetry. Surfaces records signed, cost spend, throttle events, and chain head — all filtered by the tenantId template variable.",
  "editable": true,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "Records signed (rate per minute) — tenant: $tenantId",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (action) (rate(compliance_gateway_audit_records_total{action=~\"query:.*\"}[1m])) * 60",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "LLM spend (USD, cumulative today) — tenant: $tenantId",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (provider) (compliance_gateway_cost_usd_total{tenantId=\"$tenantId\"})",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Throttled requests by reason — tenant: $tenantId",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (reason) (rate(compliance_gateway_throttle_total{tenantId=\"$tenantId\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "/v1/query p95 latency — tenant: $tenantId",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (provider) (compliance_gateway_query_latency_ms{tenantId=\"$tenantId\"})",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["audit", "trust", "tenant", "compliance-gateway"],
  "templating": {
    "list": [
      {
        "name": "tenantId",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(compliance_gateway_audit_records_total, tenantId)",
        "current": { "text": "default", "value": "default" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Audit Trust Telemetry — per Tenant",
  "uid": "audit-trust-tenant",
  "version": 1
}
