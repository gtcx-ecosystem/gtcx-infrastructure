{
  "name": "gtcx-infrastructure",
  "version": "0.1.0",
  "private": true,
  "description": "GTCX Infrastructure - Docker, Kubernetes, Terraform, security, migrations, and deployment tooling",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtcx-ecosystem/gtcx-infrastructure.git"
  },
  "author": "GTCX Protocol",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "bash ./infra/scripts/validate.sh quick",
    "test:full": "bash ./infra/scripts/validate.sh full",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "check:fine-tune-workflow-policy": "node tools/policy/check-fine-tune-workflow-policy.mjs",
    "check:workflow-image-contract": "node tools/policy/check-workflow-image-contract.mjs",
    "check:security-control-boundaries": "node tools/policy/check-security-control-boundaries.mjs",
    "check:k8s-policy": "node tools/policy/check-k8s-policy.mjs",
    "check:workspace-root-cleanliness": "python3 scripts/ops/check-workspace-root-cleanliness.py",
    "check:workspace-root-cleanliness:strict": "python3 scripts/ops/check-workspace-root-cleanliness.py --strict",
    "signal:import-cost-stats": "node scripts/ops/import-baseline-cost-stats.mjs",
    "signal:injection-witness": "node scripts/ops/run-injection-suite-witness.mjs",
    "typecheck": "turbo run typecheck",
    "ctl": "node ./tools/control-plane/gtcx-ctl.mjs",
    "evidence:release-bundle": "node ./tools/control-plane/generate-release-evidence.mjs",
    "agent:next-work": "node scripts/agent-next-work.mjs",
    "agent:launch:check": "node ../gtcx-agentic/scripts/check-agent-launch-focus.mjs",
    "agent:work-selection:check": "node scripts/check-agent-work-selection.mjs",
    "agent:execution-obligation:check": "node scripts/check-agent-execution-obligation.mjs",
    "agent:proceed-confirmation:check": "node scripts/check-agent-proceed-confirmation.mjs",
    "validate:environment": "node ./tools/control-plane/validate-environment.mjs",
    "validate:environment:ci": "node ./tools/control-plane/validate-environment.mjs --ci",
    "validate:ussd-soak": "bash ./tools/load-tests/run-ussd-soak.sh",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "build:reproducible": "SOURCE_DATE_EPOCH=${SOURCE_DATE_EPOCH:-$(git log -1 --pretty=%ct 2>/dev/null || date +%s)} turbo run build --force && node tools/scripts/verify-reproducible-build.mjs",
    "lint:shell": "shellcheck infra/scripts/*.sh",
    "quality:governance:check": "node tools/scripts/docs-standard-validator.mjs",
    "docs:check-links": "node tools/scripts/docs-link-checker.mjs",
    "prepare": "husky",
    "agent:sync": "node scripts/agent-sync/sync.mjs",
    "agent:check": "node scripts/agent-sync/sync.mjs --check",
    "score:compute": "node tools/scripts/compute-audit-scores.mjs --write",
    "agent:coordination:check": "node scripts/check-coordination-hygiene.mjs",
    "agent:start": "node scripts/agent-start.mjs",
    "agent:session-start": "pnpm run agent:start",
    "session": "node ../baseline-os/packages/baselineos/dist/cli/bin.js session",
    "next": "node ../baseline-os/scripts/ecosystem/work-next.mjs",
    "gates": "node ../baseline-os/scripts/ecosystem/human-gates-check.mjs",
    "hub": "node ../baseline-os/scripts/ecosystem/hub-sync.mjs",
    "workspace:check": "node scripts/workspace/check.mjs",
    "pm:sync": "node scripts/workspace/pm-sync.mjs",
    "pm:status": "node scripts/workspace/pm-status.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "c8": "^11.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tinyexec": "^1.2.4",
    "turbo": "^2.9.16",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=9.0.6",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=2.0.3",
      "yaml": ">=2.8.3"
    }
  },
  "gtcx": {
    "principles": [
      "P12",
      "P14",
      "P15",
      "P22",
      "P24"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
