{
  "$schema": "https://gtcx.org/schemas/hygiene-config/v1.json",
  "extends": "@gtcx/hygiene/monorepo",
  "workspace_type": "monorepo",
  "layoutVersion": "v5",
  "root": {
    "max_entries": 52,
    "max_files": 22,
    "required_dirs": ["docs"],
    "case_rules": {
      "uppercase_allowlist": ["README.md", "LICENSE", "Dockerfile", "AGENTS.md"],
      "uppercase_relocations": {
        "CHANGELOG.md": "docs/changelog.md"
      },
      "forbid_uppercase_outside_allowlist": true
    },
    "allowed_dirs": [
      "agentic",
      "archive",
      "audit",
      "deploy",
      "docs",
      "ops",
      "platform",
      "pm",
      "workstream",
      "config",
      "node_modules",
      ".github",
      ".husky",
      ".baseline",
      ".agent",
      ".claude",
      ".cursor",
      ".gemini",
      ".kimi",
      ".keys",
      ".local",
      ".turbo"
    ],
    "allowed_files": [
      "hygiene.config.json",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.json",
      "tsconfig.*.json",
      "eslint.config.js",
      "turbo.json",
      "baseline.config.json",
      "vitest.config.ts",
      "vitest.workspace.ts",
      ".editorconfig",
      ".nvmrc",
      ".gitignore",
      ".markdown-link-check.json",
      "Makefile",
      "Makefile.local",
      "AGENTS.md",
      ".env.example"
    ],
    "forbidden_patterns": [
      {
        "pattern": ".env",
        "kind": "file",
        "message": ".env must not live at repo root — use .env.example + vault",
        "severity": "P1"
      },
      {
        "pattern": ".env.local",
        "kind": "file",
        "severity": "P1"
      }
    ]
  },
  "naming": {
    "docs_case": "kebab",
    "exceptions": [
      "docs/README.md",
      "docs/**/README.md",
      "docs/AGENTS.md",
      "archive/**/README.md",
      "audit/**/README.md"
    ]
  },
  "build_artifacts": {
    "must_be_gitignored": ["dist/", "build/", ".next/", ".turbo/", "coverage/", "node_modules/"]
  },
  "per_directory_readme": {
    "min_chars": 120,
    "exceptions": [
      ".github",
      ".husky",
      ".baseline",
      ".agent",
      ".claude",
      ".cursor",
      ".gemini",
      ".kimi",
      ".keys",
      ".local",
      ".turbo"
    ]
  },
  "score_targets": {
    "fail_ci_below": 7.0,
    "strict_ci": false
  }
}
