{
  "$schema": "https://gtcx.org/schemas/hygiene-config/v1.json",
  "extends": "@gtcx/hygiene/monorepo",
  "workspace_type": "monorepo",
  "root": {
    "max_entries": 70,
    "max_files": 35,
    "required_dirs": ["docs"],
    "case_rules": {
      "uppercase_allowlist": ["README.md", "LICENSE", "Dockerfile", "AGENTS.md", "CHANGELOG.md"],
      "uppercase_relocations": {
        "CHANGELOG.md": "docs/changelog.md"
      },
      "forbid_uppercase_outside_allowlist": true
    },
    "allowed_dirs": [
      "agentic",
      "archive",
      "audit",
      "authority-trace-evidence",
      "deploy",
      "docs",
      "ops",
      "platform",
      "pm",
      "workstream",
      "config",
      "services",
      "apps",
      "packages",
      "node_modules",
      ".github",
      ".husky",
      ".baseline",
      ".agent",
      ".claude",
      ".cursor",
      ".gemini",
      ".kimi",
      ".keys",
      ".local",
      ".turbo"
    ],
    "allowed_files": [
      "hygiene.config.json",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.json",
      "tsconfig.*.json",
      "eslint.config.js",
      "turbo.json",
      "baseline.config.json",
      "vitest.config.ts",
      "vitest.workspace.ts",
      "pyproject.toml",
      ".editorconfig",
      ".nvmrc",
      ".gitignore",
      ".markdown-link-check.json",
      "Makefile",
      "Makefile.local",
      "AGENTS.md",
      "CHANGELOG.md",
      ".env.example",
      ".env.staging.example",
      ".dockerignore",
      ".npmrc",
      ".pre-commit-config.yaml",
      ".prettierignore",
      ".prettierrc",
      ".vercelignore",
      "eslint.config.mjs",
      ".lighthouserc.json",
      ".lintstagedrc.cjs"
    ],
    "forbidden_patterns": [
      {
        "pattern": ".env",
        "kind": "file",
        "message": ".env must not live at repo root — use .env.example + vault",
        "severity": "P1"
      },
      {
        "pattern": ".env.local",
        "kind": "file",
        "severity": "P1"
      },
      {
        "pattern": ".env.staging",
        "kind": "file",
        "message": ".env.staging must not live at repo root — use vault or .env.staging.example",
        "severity": "P1"
      },
      {
        "pattern": ".DS_Store",
        "kind": "file",
        "severity": "P1"
      }
    ]
  },
  "naming": {
    "docs_case": "kebab",
    "exceptions": [
      "docs/README.md",
      "docs/**/README.md",
      "docs/AGENTS.md",
      "docs/specs/experiences/EXR-*.md",
      "archive/**/README.md",
      "audit/**/README.md"
    ]
  },
  "build_artifacts": {
    "must_be_gitignored": ["dist/", "build/", ".next/", ".turbo/", "coverage/", "node_modules/"]
  },
  "archive": {
    "human_owned_paths": ["_delete/", "archive", "archive/"],
    "stale_dir_patterns": []
  },
  "empty_dirs": {
    "allowed": ["**"]
  },
  "per_directory_readme": {
    "min_chars": 120,
    "exceptions": [
      ".github",
      ".husky",
      ".baseline",
      ".agent",
      ".claude",
      ".cursor",
      ".gemini",
      ".kimi",
      ".keys",
      ".local",
      ".turbo",
      "authority-trace-evidence",
      "deploy"
    ]
  },
  "score_targets": {
    "fail_ci_below": 7,
    "strict_ci": false
  }
}
